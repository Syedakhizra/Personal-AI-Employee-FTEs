AI_Employee_Vault/watchers/token.json
gmail_send_token.json
gmail_session.json
gmail_api_token.json

# ============================================================
# LINKEDIN SESSION (CRITICAL!)
# ============================================================
linkedin_session.json
linkedin_send_token.json

# ============================================================
